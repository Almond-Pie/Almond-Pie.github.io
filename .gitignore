# Allowlist approach: ignore everything by default, then explicitly
# un-ignore only what the live site actually references.
*
!*/

# Site pages + scripts
!/Aphos.html
!/BuildToLast.html
!/Capoeira.html
!/CS500.html
!/Explorations.html
!/Bespoke.html
!/Portfolio.html
!/index.html
!/Voucht.html
!/image-slot.js
!/.gitignore
!/README.md

# Site assets
!/Aphos/**
!/Voucht/**
!/Video Ad's/**
!/assets/**
# Bespoke: only the web-optimised assets (not the multi-GB source renders/shortcuts)
!/Bespoke/**/*.jpg
!/Bespoke/**/*.mp4

# Re-exclude things that snuck back in via the folder allowlists above
Video Ad's/Base 44 Spec Ad-source.mp4
# Bulky source videos (only the web-optimised versions are committed)
Bespoke/Video/Bespoke_Mens.mp4
Bespoke/Video/Bespoke_Womens.mp4
assets/cs500/Pan_out_CS_500.mp4
assets/cs500/W.I.P/
# CS-500 source renders (only the web-optimised jpgs are committed)
assets/cs500/*.png
*.af
*.af~lock~
**/node_modules/
**/.next/
**/dist/
**/build/
*.log
Thumbs.db
.DS_Store
